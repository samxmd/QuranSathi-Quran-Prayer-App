{
  "expo": {
    "name": "QuranSathi",
    "slug": "quransathi",
    "version": "1.0.5",
    "updates": {
      "enabled": false,
      "checkAutomatically": "NEVER"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "quran-app",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#003D29"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fossatechnology.quransathi",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "QuranSathi uses your location to show prayer times and Qibla direction.",
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "package": "com.fossatechnology.quransathiapp",
      "versionCode": 6,
      "blockedPermissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "permissions": [
        "INTERNET",
        "POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_AUDIO",
        "android.permission.WAKE_LOCK",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#003D29"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "QuranSathi uses your location to show prayer times and Qibla direction."
        }
      ],
      [
        "expo-audio",
        {
          "enableBackgroundPlayback": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#003D29"
        }
      ],
      "expo-sqlite",
      "expo-asset",
      [
        "@sentry/react-native/expo",
        {
          "organization": "fossa-technology",
          "project": "react-native"
        }
      ],
      "@react-native-firebase/app",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "kotlinVersion": "2.0.21",
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true,
      "baseUrl": ""
    },
    "extra": {
      "router": {
        "origin": "http://localhost:8081",
        "baseUrl": ""
      },
      "eas": {
        "projectId": "13a8b149-65de-410d-acb8-e012dfbe4de6"
      }
    },
    "owner": "sam.amd"
  }
}
